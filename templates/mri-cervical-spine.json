    {
      "id": "technique",
      "title": "Методика дослідження",
      "type": "free_text",
      "defaultText": "МРТ шийного відділу хребта виконана на томографі 1.5Т. Отримано зображення у сагітальній площині (Т1-ЗЗ, Т2-ЗЗ, STIR) та аксіальній площині (Т2-ЗЗ) на рівні міжхребцевих дисків."
    },
    {
      "id": "quality",
      "title": "Якість дослідження",
      "type": "free_text",
      "defaultText": "Якість дослідження задовільна. Артефакти руху мінімальні."
    },
    {
      "id": "comparison",
      "title": "Порівняння",
      "type": "free_text",
      "defaultText": "Попередні дослідження для порівняння відсутні.",
      "placeholder": "Порівняння з попередніми дослідженнями (дата, метод)"
    },
    {
      "id": "findings",
      "title": "Опис",
      "type": "group",
      "subsections": [
        {
          "id": "alignment",
          "title": "Вісь та вирівнювання",
          "defaultText": "Фізіологічний лордоз шийного відділу хребта збережений. Лістезу немає. Вісь хребта не відхилена."
        },
        {
          "id": "vertebral_bodies",
          "title": "Тіла хребців С1–С7",
          "defaultText": "Тіла хребців С1–С7 звичайної висоти та МР-сигналу, без деструктивних змін, компресійних переломів та патологічних вогнищ. Зубоподібний відросток С2 без особливостей. Атланто-аксіальне співвідношення не порушене."
        },
        {
          "id": "discs",
          "title": "Міжхребцеві диски",
          "defaultText": "С2–С3: диск звичайної висоти та сигналу, протрузій та гриж немає.\nС3–С4: диск звичайної висоти та сигналу, протрузій та гриж немає.\nС4–С5: диск звичайної висоти та сигналу, протрузій та гриж немає.\nС5–С6: диск звичайної висоти та сигналу, протрузій та гриж немає.\nС6–С7: диск звичайної висоти та сигналу, протрузій та гриж немає.\nС7–Т1: диск звичайної висоти та сигналу, протрузій та гриж немає."
        },
        {
          "id": "spinal_cord",
          "title": "Спинний мозок",
          "defaultText": "Спинний мозок на рівні шийного відділу нормального калібру та однорідного МР-сигналу, без ознак компресії, вогнищ мієлопатії та патологічних інтрамедулярних змін."
        },
        {
          "id": "spinal_canal",
          "title": "Хребтовий канал",
          "defaultText": "Хребтовий канал не звужений на всіх рівнях шийного відділу. Сагітальний розмір каналу в межах норми."
        },
        {
          "id": "foramina",
          "title": "Міжхребцеві отвори",
          "defaultText": "Міжхребцеві (невральні) отвори не звужені з обох боків на всіх рівнях."
        },
        {
          "id": "facet_joints",
          "title": "Дугоподібні суглоби",
          "defaultText": "Дугоподібні (фасеткові) суглоби без ознак значного артрозу, гіпертрофії чи випоту."
        },
        {
          "id": "paravertebral",
          "title": "Паравертебральні м'які тканини",
          "defaultText": "Паравертебральні м'які тканини без патологічних змін. Превертебральні м'які тканини не потовщені."
        }
      ]
    },
