{
  "id": "mri-lumbar-spine",
  "name": "МРТ поперекового відділу хребта",
  "modality": "MRI",
  "bodyPart": "lumbar-spine",
  "language": "uk",
  "version": "1.0.0",
  "sections": [
    {
      "id": "patient_info",
      "title": "Дані пацієнта",
      "type": "group",
      "subsections": [
        { "id": "patient_name", "title": "ПІБ пацієнта", "defaultText": "" },
        { "id": "patient_dob", "title": "Дата народження пацієнта", "defaultText": "", "placeholder": "ДД/ММ/РРРР" },
        { "id": "patient_id", "title": "ID пацієнта", "defaultText": "" },
        { "id": "exam_date", "title": "Дата обстеження", "defaultText": "", "placeholder": "ДД/ММ/РРРР" }
      ]
    },
    {
      "id": "clinical_info",
      "title": "Клінічна інформація",
      "type": "free_text",
      "defaultText": "Не надано.",
      "placeholder": "Показання: люмбалгія / радикулопатія / синдром кінського хвоста / травма / контроль після операції / інше"
    },
    {
      "id": "technique",
      "title": "Методика дослідження",
      "type": "free_text",
      "defaultText": "МРТ поперекового відділу хребта виконана на томографі 1.5Т. Отримано зображення у сагітальній площині (Т1-ЗЗ, Т2-ЗЗ, STIR) та аксіальній площині (Т2-ЗЗ) на рівні міжхребцевих дисків."
    },
    {
      "id": "quality",
      "title": "Якість дослідження",
      "type": "free_text",
      "defaultText": "Якість дослідження задовільна. Артефакти руху мінімальні."
    },
    {
      "id": "comparison",
      "title": "Порівняння",
      "type": "free_text",
      "defaultText": "Попередні дослідження для порівняння відсутні.",
      "placeholder": "Порівняння з попередніми дослідженнями (дата, метод)"
    },
    {
      "id": "findings",
      "title": "Опис",
      "type": "group",
      "subsections": [
        {
          "id": "alignment",
          "title": "Вісь та вирівнювання",
          "defaultText": "Фізіологічний лордоз поперекового відділу хребта збережений. Лістезу немає. Вісь хребта не відхилена, сколіотичної деформації не визначається."
        },
        {
          "id": "vertebral_bodies",
          "title": "Тіла хребців L1–L5, S1",
          "defaultText": "Тіла хребців L1–L5 та S1 звичайної висоти та МР-сигналу, без деструктивних змін, компресійних переломів та патологічних вогнищ. Перехідних хребців не визначається."
        },
        {
          "id": "discs",
          "title": "Міжхребцеві диски",
          "defaultText": "L1–L2: диск звичайної висоти та сигналу, протрузій та гриж немає.\nL2–L3: диск звичайної висоти та сигналу, протрузій та гриж немає.\nL3–L4: диск звичайної висоти та сигналу, протрузій та гриж немає.\nL4–L5: диск звичайної висоти та сигналу, протрузій та гриж немає.\nL5–S1: диск звичайної висоти та сигналу, протрузій та гриж немає."
        },
        {
          "id": "conus_cauda",
          "title": "Конус спинного мозку та кінський хвіст",
          "defaultText": "Конус спинного мозку закінчується на рівні L1–L2, нормальної форми та МР-сигналу. Корінці кінського хвоста рівномірно розподілені, без ущільнень, злипань та потовщень."
        },
        {
          "id": "spinal_canal",
          "title": "Хребтовий канал",
          "defaultText": "Хребтовий канал не звужений на всіх рівнях поперекового відділу. Сагітальний розмір каналу в межах норми."
        },
        {
          "id": "foramina",
          "title": "Міжхребцеві отвори",
          "defaultText": "Міжхребцеві (невральні) отвори не звужені з обох боків на всіх рівнях. Латеральні рецесуси вільні."
        },
        {
          "id": "facet_joints",
          "title": "Дугоподібні суглоби",
          "defaultText": "Дугоподібні (фасеткові) суглоби без ознак значного артрозу, гіпертрофії чи випоту."
        },
        {
          "id": "paravertebral",
          "title": "Паравертебральні м'які тканини",
          "defaultText": "Паравертебральні м'які тканини без патологічних змін. Поперекові м'язи симетричні, без жирової атрофії."
        }
      ]
    },
    {
      "id": "impression",
      "title": "Висновок",
      "type": "free_text",
      "defaultText": "МР-ознаки патологічних змін поперекового відділу хребта не виявлено."
    },
    {
      "id": "recommendations",
      "title": "Рекомендації",
      "type": "free_text",
      "defaultText": "",
      "placeholder": "Рекомендації щодо подальшого обстеження, консультації, контрольного дослідження"
    }
  ],
